{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Sync Themes to EFC",
      "type": "shell",
      "command": "bash .vscode/sync-themes.sh",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "clear": true }
    },
    {
      "label": "Sync Themes to EFC (dry-run)",
      "type": "shell",
      "command": "bash .vscode/sync-themes.sh --dry-run",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "clear": true }
    }
  ]
}
